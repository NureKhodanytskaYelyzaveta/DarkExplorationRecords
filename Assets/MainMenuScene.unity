  m_text: "\u0427\u0438 \u0431\u0443\u043B\u043E \u0443 \u0432\u0430\u0441 \u0442\u0430\u043A\u0435,
    \u0449\u043E \u0432\u0438 \u043F\u043E \u0441\u0430\u043C\u0456 \u0432\u0443\u0445\u0430
    \u0431\u0443\u043B\u0438 \u0447\u0438\u043C\u043E\u0441\u044C \u0437\u0430\u0445\u043E\u043F\u043B\u0435\u043D\u0456?\n\u042F
    \u043D\u0435 \u043A\u0430\u0436\u0443 \u043F\u0440\u043E \u0437\u0432\u0438\u0447\u0430\u0439\u043D\u0435:
    \u201C\u041E, \u043F\u0440\u0438\u043A\u043E\u043B\u044C\u043D\u043E\u201D, \u0430
    \u043F\u0440\u043E \u0442\u0435, \u0449\u043E \u0432\u0440\u0430\u0437\u0438\u043B\u043E
    \u0432\u0430\u0441 \u043D\u0430\u0441\u0442\u0456\u043B\u044C\u043A\u0438, \u0449\u043E
    \u0437\u0440\u0435\u0448\u0442\u043E\u044E \u0432\u0438 \u0432\u0438\u0442\u0440\u0430\u0442\u0438\u043B\u0438
    \u043D\u0430 \u0446\u0435 \u0437\u0430\u0439\u0432\u0456 \u0447\u0430\u0441 \u0442\u0430
    \u0433\u0440\u043E\u0448\u0456."
